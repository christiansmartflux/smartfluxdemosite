                            <span class="font-bold">v.a. € 70,00</span>
                        </div>
                    </div>
                </div>
                <div class="bg-white p-8 rounded-2xl boutique-shadow">
                    <h3 class="text-2xl font-headline font-bold mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined">child_care</span> Kinderen
                    </h3>
                    <div class="flex justify-between items-center py-3 border-b">
                        <span>Tot 4 jaar</span>
                        <span class="font-bold">€ 19,00</span>
                    </div>
                    <div class="flex justify-between items-center py-3 border-b">
                        <span>4 tot 12 jaar</span>
                        <span class="font-bold">€ 20,50</span>
                    </div>
                </div>
            </div>
        </div>
